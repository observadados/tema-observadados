t:cover;object-position:center}.painel-thumbnail{display:block;padding:0 15px;overflow:hidden;text-align:center;margin-bottom:1.5rem;margin-top:-2rem;height:0;padding-top:20%;position:relative;overflow:hidden}.painel-thumbnail img{width:100%;height:auto;position:absolute;left:50%;top:50%;transform:translate(-50%, -50%)}.paineis-grid{display:flex;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;list-style:none;padding:0;margin:0}@media(min-width: 768px){.paineis-grid{width:calc(100% + 2rem);margin-left:-1rem;margin-right:-1rem}}.paineis-grid li{width:100%;padding:0;margin-bottom:2rem}@media(min-width: 768px){.paineis-grid li{width:50%;padding:0 1rem}}.paineis-grid li>a{display:block;background:#fff;border-radius:15px;padding:1.25rem 1.25rem .25rem}.paineis-grid li>a:hover figure,.paineis-grid li>a:focus figure{opacity:.8}.paineis-grid li>a figure{position:relative;overflow:hidden;height:0;overflow:hidden;padding-top:50%;margin:0 auto 1rem;transition:all .4s ease;background:#eaeaea;border-radius:10px}@media(min-width: 768px){.paineis-grid li>a figure{max-width:none}}.paineis-grid li>a figure img{width:100%;height:auto;position:absolute;left:50%;top:50%;transform:translate(-50%, -50%);aspect-ratio:2/1;object-fit:cover}.paineis-grid li>a h2{font-family:"Outfit",sans-serif;font-size:1.25rem;position:relative;text-transform:none;margin-bottom:.5rem;color:#34483f;font-weight:bold !important;line-height:1.2;padding-left:.5rem}.paineis-grid li>a p{padding-left:.5rem}.paineis-grid li>a p.categoria{color:#97341a;margin-bottom:.5rem !important}.paineis-grid li>a p.categoria.indisponivel{color:#919191}.paineis-grid li>a p.modalidade{color:#fff;margin-bottom:.5rem !important;border-radius:4px;font-size:.875rem;font-weight:bold;display:inline-block;padding:0 .5em !important;margin-left:.5rem}.paineis-grid li>a p.modalidade.presencial{background:#34483f}.paineis-grid li>a p.modalidade.online{background:#97341a}.paineis-grid li>a h3{font-size:1rem;text-transform:none;margin-bottom:.5rem;font-weight:bold;padding-left:.5rem}.spearkers-list{display:flex;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;list-style:none;padding:0 !important;margin:0 0 2rem !important}@media(min-width: 768px){.spearkers-list{width:calc(100% + 1rem);margin-left:-0.5rem !important;margin-right:-0.5rem !important}}.spearkers-list li{width:100%;padding:0;margin-bottom:2rem}@media(min-width: 768px){.spearkers-list li{width:50%;padding:0 .5rem}}.spearkers-list li>a{display:block;margin-top:80px;background:#fff;text-decoration:none !important;padding:1rem;text-align:center;box-shadow:0 0 10px rgba(52,72,63,.2) !important;transition:all .3s ease-in-out}.spearkers-list li>a:hover,.spearkers-list li>a:focus{box-shadow:0 0 20px rgba(52,72,63,.3) !important}.spearkers-list li>a:hover figure,.spearkers-list li>a:focus figure{box-shadow:0 0 10px rgba(52,72,63,.3) !important}.spearkers-list li>a:hover .badge,.spearkers-list li>a:focus .badge{background:#97341a}.spearkers-list li>a .badge{background:#34483f;color:#fff;display:inline-block;border-radius:20px;padding:.25rem .5rem;font-size:.875rem;margin-top:.5rem;transition:all .3s ease-in-out}.spearkers-list li>a figure{position:relative;overflow:hidden;height:0;overflow:hidden;margin:0 auto 1rem;transition:all .4s ease;background:#eaeaea;border:2px solid rgba(52,72,63,.8);width:160px;height:160px;margin-top:-80px;border-radius:50%}@media(min-width: 768px){.spearkers-list li>a figure{max-width:none}}.spearkers-list li>a figure img{width:102%;max-width:none;height:auto;position:absolute;left:50%;top:50%;transform:translate(-50%, -50%)}.spearkers-list li>a h3{font-size:1rem;text-transform:none;margin-bottom:0 !important;font-weight:bold}.spearkers-list li>a p{margin-bottom:0 !important;line-height:1.2 !important}.title-spearkers{margin-top:2rem !important}.story-content h3{margin-top:1rem !important}.sessoes-container .sessao{margin:0 0 2rem;border-radius:10px;background:#fff;box-shadow:0 0 10px rgba(0,0,0,.25);padding:15px}.sessoes-container .sessao h3{background:#5a7a4f;color:#fff;padding:.25rem .5rem;border-radius:5px}.sessoes-container .sessao .sessao-info{line-height:1.25;border-bottom:1px solid #ccc;padding-bottom:1rem;margin-bottom:1rem}.sessoes-container .sessao .sessao-trabalhos{list-style:none;padding:0 !important;margin:0 !important}.sessoes-container .sessao .sessao-trabalhos li{border-bottom:1px solid #ccc;padding-bottom:1rem;margin-bottom:1rem;line-height:1.25}.sessoes-container .sessao .sessao-trabalhos li:last-of-type{border:none;padding-bottom:0}.sessoes-container .sessao .sessao-trabalhos li h4{margin:0 !important;line-height:1.25 !important}.sessoes-container .sessao .sessao-trabalhos li p{margin:0 !important}.grecaptcha-badge{bottom:60px !important}.cool-vertical-timeline-body .timeline-content .story-details{box-shadow:0 0 5px rgba(0,0,0,.15)}/*# sourceMappingURL=theme.csss.map */
